# ════════════════════════════════════════════════════════════════
#  SpendWise — root .gitignore
# ════════════════════════════════════════════════════════════════

# ── Secrets (NEVER commit these) ────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
**/.env
**/.env.local
**/.env.production
# .env.example is safe to commit — it has no real values

# ── macOS ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Editor / IDE ─────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.cursor/

# ── Project planning docs (personal notes, not source code) ──────
PREMIUM_UI_REDESIGN_PROMPT.md
SpendWise_AI_Master_Prompt.md

# ════════════════════════════════════════════════════════════════
#  FRONTEND (Next.js)
# ════════════════════════════════════════════════════════════════

frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
frontend/tsconfig.tsbuildinfo
frontend/next-env.d.ts
frontend/.vercel/

# Capacitor native project folders (generated — not source)
frontend/ios/
frontend/android/

# Test coverage
frontend/coverage/

# ════════════════════════════════════════════════════════════════
#  BACKEND (FastAPI / Python)
# ════════════════════════════════════════════════════════════════

# Python
backend/__pycache__/
backend/**/__pycache__/
backend/*.pyc
backend/**/*.pyc
backend/*.pyo
backend/*.pyd
backend/.Python

# Virtual environments
backend/.venv/
backend/venv/
backend/env/
backend/.env/

# Pytest / coverage
backend/.pytest_cache/
backend/htmlcov/
backend/.coverage
backend/coverage.xml

# mypy / pyright
backend/.mypy_cache/
backend/.pyright/

# Distribution / packaging
backend/dist/
backend/build/
backend/*.egg-info/

# Alembic — keep migrations but ignore pycache inside
backend/alembic/__pycache__/

# ML model artifacts (large binary files)
backend/app/ml/*.pkl
backend/app/ml/*.joblib
backend/app/ml/*.h5
backend/app/ml/models/

# Logs
backend/logs/
backend/*.log
*.log

# ════════════════════════════════════════════════════════════════
#  DOCKER / INFRA
# ════════════════════════════════════════════════════════════════

# Override files (contain local ports/passwords)
docker-compose.override.yml

# ════════════════════════════════════════════════════════════════
#  MISC
# ════════════════════════════════════════════════════════════════

*.pem
*.key
*.cert
*.p12
*.pfx
