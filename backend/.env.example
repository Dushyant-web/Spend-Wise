# ── SpendWise Backend Environment Variables ───────────────────────────────────
# Copy this file to .env for local development
# Set these in your Render dashboard for production (render.yaml handles most of them)

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development            # production | development
DEBUG=true                     # false in production

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-256-bit-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
# Local:
DATABASE_URL=postgresql+asyncpg://spendwise:spendwise_dev@localhost:5432/spendwise
# Render injects this automatically via render.yaml

# ── Redis ──────────────────────────────────────────────────────────────────────
# Local:
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# Render injects these automatically via render.yaml

# ── AI (NVIDIA NIM) ────────────────────────────────────────────────────────────
# Get your key at: https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# ── CORS Origins ───────────────────────────────────────────────────────────────
# Add your Netlify URL and mobile origins
ALLOWED_ORIGINS=["http://localhost:3000","https://your-app.netlify.app","capacitor://localhost","http://localhost"]

# ── Cloudinary (optional — for profile picture uploads) ───────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Sentry (optional — for error tracking) ────────────────────────────────────
SENTRY_DSN=
